        {
          "schema_version": 0,
          "attributes": {
            "id": "2699641856",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::283236069347:oidc-provider/oidc.eks.ap-southeast-1.amazonaws.com/id/F5B6491AB29D52571E0E29F01470DAEE\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.ap-southeast-1.amazonaws.com/id/F5B6491AB29D52571E0E29F01470DAEE:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.ap-southeast-1.amazonaws.com/id/F5B6491AB29D52571E0E29F01470DAEE:sub\": \"system:serviceaccount:kube-system:aws-load-balancer-controller\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"sts:AssumeRoleWithWebIdentity\",\"Principal\":{\"Federated\":\"arn:aws:iam::283236069347:oidc-provider/oidc.eks.ap-southeast-1.amazonaws.com/id/F5B6491AB29D52571E0E29F01470DAEE\"},\"Condition\":{\"StringEquals\":{\"oidc.eks.ap-southeast-1.amazonaws.com/id/F5B6491AB29D52571E0E29F01470DAEE:aud\":\"sts.amazonaws.com\",\"oidc.eks.ap-southeast-1.amazonaws.com/id/F5B6491AB29D52571E0E29F01470DAEE:sub\":\"system:serviceaccount:kube-system:aws-load-balancer-controller\"}}}]}",
